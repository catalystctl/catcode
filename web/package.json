{
  "name": "catalyst-code-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "node --import tsx src/server/server.ts",
    "build": "node node_modules/next/dist/bin/next build && node scripts/write-version.mjs",
    "start": "NODE_ENV=production node --import tsx src/server/server.ts",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "audit:mobile": "node scripts/mobile-audit.mjs",
    "postinstall": "node scripts/fix-sdk-link.mjs"
  },
  "dependencies": {
    "@better-auth/kysely-adapter": "^1.6.23",
    "@better-auth/passkey": "^1.6.23",
    "@catalyst-code/coding-agent": "file:../sdk",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/outfit": "^5.2.8",
    "@lydell/node-pty": "1.2.0-beta.12",
    "better-auth": "^1.6.23",
    "ghostty-web": "^0.4.0",
    "highlight.js": "^11.11.1",
    "kysely": "^0.29.3",
    "monaco-editor": "^0.55.1",
    "next": "^15.5.20",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^9.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
