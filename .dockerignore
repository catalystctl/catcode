# Build-context shrinkage for the Dockerfile (it only COPYs core/ and tui/).
# Exclude everything the image doesn't need so `docker build` is fast + cacheable.

.git/
.gitignore
.github/
.pi/
.catalyst-code/
continue/
roo-code/
dist/
*.log
*.log.*
context.md
plan.md
plan.html

# Stray binaries + build dirs (keep the image reproducible & lean)
core/target/
tui/tui
tui/catalyst-code-tui
tui/catcode
tui/catcode.exe
tui/bin/
tui/embed/catcode-core
**/*.rs.bk

# OS / editor junk
.DS_Store
Thumbs.db
*.swp
*.swo
node_modules/
